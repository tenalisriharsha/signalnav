rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Intersections: public read, admin write
    match /intersections/{intersectionId} {
      allow read: if true;
      allow write: if false; // Only via admin/SDK
    }

    // Signal reports: authenticated write, system read (for aggregation)
    match /signal_reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['intersection_id', 'phase', 'color', 'timestamp', 'device_hash'])
        && !request.resource.data.keys().hasAny(['uid', 'user_id', 'email', 'exact_location']);
      allow read: if false; // Only backend scripts read these
      allow update, delete: if false;
    }

    // Predictions: public read, backend write
    match /predictions/{predictionId} {
      allow read: if true;
      allow write: if false; // Only backend scripts
    }

    // Users: private per-user
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deletion requests: user can create their own, backend can update
    match /deletion_requests/{requestId} {
      allow create: if request.auth != null && request.auth.uid == requestId;
      allow read: if request.auth != null && request.auth.uid == requestId;
      allow update, delete: if false; // Only backend scripts
    }
  }
}
