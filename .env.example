# SignalNav Environment Configuration
# Copy this file to .env and fill in your actual API keys

# ===================== ROUTING =====================
# Self-hosted OSRM base URL. Default is localhost for development.
# For production, use your deployed OSRM instance or leave empty to use GraphHopper fallback.
OSRM_BASE_URL=http://localhost:5000

# GraphHopper Directions API key (free tier: 500 credits/day)
# Get one at: https://www.graphhopper.com/
GRAPH_HOPPER_API_KEY=YOUR_GRAPH_HOPPER_KEY

# ===================== TRAFFIC =====================
# TomTom Traffic API key (free: 2,500 requests/day)
# Get one at: https://developer.tomtom.com/
TOMTOM_API_KEY=YOUR_TOMTOM_KEY

# ===================== FIREBASE =====================
# Firebase project configuration is handled via google-services.json (Android)
# and GoogleService-Info.plist (iOS). No keys needed here.
